# Authenticity - Docker Environment
# Copy ke .env dan sesuaikan nilai

# Port untuk aplikasi (default: 8003)
APP_PORT=127.0.0.1:8003

# Database - MySQL di host/WSL
# Pastikan MySQL di host sudah running dan allow remote dari Docker
DB_HOST=host.docker.internal
DB_PORT=3306
DB_DATABASE=gridsf
DB_USERNAME=root
DB_PASSWORD=admin123
