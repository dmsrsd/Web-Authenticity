# Authenticity - Docker Environment
# Copy ke .env dan sesuaikan nilai (cp .env.example .env)

# --- Port aplikasi ---
# Lokal/WSL: bind localhost saja
# APP_PORT=127.0.0.1:8003
# EC2/produksi: bind semua interface agar bisa diakses dari internet
APP_PORT=0.0.0.0:80

# --- Database: MySQL di host (bukan di container) ---
# Docker resolve host via host.docker.internal (Linux: extra_hosts host-gateway)
DB_HOST=host.docker.internal
DB_PORT=3306
DB_DATABASE=gridsf
DB_USERNAME=root
DB_PASSWORD=admin123
